{
    "layer": "top",
    "position": "top",
    "margin-left": 7,
    "margin-right": 7,
    "margin-top": 2,
    "height": 26,
    "spacing": 3,
    "reload_style_on_change": true,
    "font-family": "JetBrainsMono Nerd Font, monospace",

    "modules-left": ["custom/arch-logo","hyprland/workspaces"],
    "modules-center": ["clock","custom/cava_mviz","idle_inhibitor"],
    "modules-right": ["pulseaudio#microphone","group/audio","custom/swaync","tray"],

    "custom/arch-logo": {
        "format": "¾░Żć",
        "on-click": "vicinae toggle",
        "tooltip": true,
	"tooltip-format": "Open Launcher"
    },

    "group/audio": {
        "orientation": "horizontal",
        "tooltip": false,
        "drawer": {
            "transition-duration": 500
        },
        "modules": [
            "wireplumber",
            "pulseaudio/slider"
        ]
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "tooltip": false,
        "on-scroll-down": "hyprctl dispatch workspace +1",
        "on-scroll-up": "hyprctl dispatch workspace -1",
        "format-icons": {
            "active": "’åÆ ",
            "default": "’äæ "
        },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },

    "clock": {
        "interval": 1,
        "tooltip": true,
        "format": "’É║ {:%H:%M}",
        "format-alt": "{:%a, %b %d, %Y (%H:%M:%S)}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_down",
            "on-scroll-down": "shift_up"
        }
    },

    "wireplumber": {
        "format": "¾░ĢŠ {volume}%",
        "format-muted": "¾░¢ü",
        "max-volume": 100,
        "scroll-step": 5,
        "on-click-right": "pwvucontrol",
        "on-click": "pamixer -t",
        "tooltip": true,
        "tooltip-format": "Volume: {volume}%"
    },

    "tray": {
        "icon-size": 18,
        "spacing": 5,
        "tooltip": false,
        "ignored-icons": [
            "waybar"
        ]
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "’ä░",
        "format-source-muted": "’ä▒",
        "on-click": "pamixer --default-source -t",
        "on-click-right": "pwvucontrol -t 3",
        "tooltip": true,
        "tooltip-format": "{source_desc} | {source_volume}%",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5"
    },

    "custom/swaync": {
        "tooltip": true,
        "tooltip-format": "Left Click: Notifications\nRight Click: Do Not Disturb",
        "format": "{icon}",
        "format-icons": {
            "notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
            "none": "’éó",
            "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
            "dnd-none": "’ćĘ",
            "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
            "inhibited-none": "’éó",
            "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
            "dnd-inhibited-none": "’ćĘ"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "sleep 0.1 && swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "custom/cava_mviz": {
        "exec": "~/.config/hypr/scripts/WaybarCava.sh",
        "format": "{}",
        "tooltip": false,
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-click-middle": "playerctl previous"
    },

    "pulseaudio/slider": {
        "min": 0,
        "max": 100,
        "orientation": "horizontal"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip": true,
        "tooltip-format": "Idle Inhibitor",
        "format-icons": {
            "activated": "’ü«",
            "deactivated": "’ü░"
        }
    }
}
